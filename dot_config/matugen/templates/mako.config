anchor=top-right
margin=10
padding=12
width=350
height=100
border-size=1
border-radius=0
font=Hiragino Sans 12
icons=1
icon-path=/usr/share/icons/hicolor
max-icon-size=48
markup=1
actions=1
format=<b>%s</b>\n%b
default-timeout=5000
ignore-timeout=0

background-color=#{{colors.surface.default.hex_stripped}}
text-color=#{{colors.on_surface.default.hex_stripped}}
border-color=#{{colors.primary.default.hex_stripped}}
progress-color=over #{{colors.primary_container.default.hex_stripped}}

[urgency=low]
background-color=#{{colors.surface.default.hex_stripped}}
text-color=#{{colors.on_surface.default.hex_stripped}}
border-color=#{{colors.outline.default.hex_stripped}}

[urgency=normal]
background-color=#{{colors.surface.default.hex_stripped}}
text-color=#{{colors.on_surface.default.hex_stripped}}
border-color=#{{colors.primary.default.hex_stripped}}

[urgency=high]
background-color=#{{colors.error_container.default.hex_stripped}}
text-color=#{{colors.on_error_container.default.hex_stripped}}
border-color=#{{colors.error.default.hex_stripped}}
