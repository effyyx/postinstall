#General
shell-integration = fish
confirm-close-surface = false
quit-after-last-window-closed = false
resize-overlay = never

#Fonts
font-family = yumin
font-size = 12

#Clipboard
clipboard-read = allow
clipboard-write = allow

background = {{colors.surface.default.hex_stripped}}
foreground = {{colors.on_surface.default.hex_stripped}}
cursor-color = {{colors.primary.default.hex_stripped}}
cursor-text = {{colors.on_primary.default.hex_stripped}}
selection-background = {{colors.primary_container.default.hex_stripped}}
selection-foreground = {{colors.on_primary_container.default.hex_stripped}}

# black / bright black
palette = 0={{colors.surface.default.hex_stripped}}
palette = 8={{colors.surface_bright.default.hex_stripped}}
# red / bright red
palette = 1={{colors.error.default.hex_stripped}}
palette = 9={{colors.error_container.default.hex_stripped}}
# green / bright green (tertiary)
palette = 2={{colors.tertiary.default.hex_stripped}}
palette = 10={{colors.tertiary_container.default.hex_stripped}}
# yellow / bright yellow (secondary)
palette = 3={{colors.secondary.default.hex_stripped}}
palette = 11={{colors.secondary_fixed.default.hex_stripped}}
# blue / bright blue (primary container)
palette = 4={{colors.primary_container.default.hex_stripped}}
palette = 12={{colors.primary.default.hex_stripped}}
# magenta / bright magenta
palette = 5={{colors.inverse_primary.default.hex_stripped}}
palette = 13={{colors.primary_fixed_dim.default.hex_stripped}}
# cyan / bright cyan
palette = 6={{colors.tertiary_fixed_dim.default.hex_stripped}}
palette = 14={{colors.tertiary_fixed.default.hex_stripped}}
# white / bright white
palette = 7={{colors.on_surface_variant.default.hex_stripped}}
palette = 15={{colors.on_surface.default.hex_stripped}}
